# Vantage meetings backend — copy to ".env" and fill in. NEVER commit the real .env.
# Run the backend with:  node --env-file=.env server/index.js   (Node 20+)

# --- Zoom (marketplace.zoom.us → Develop → Build App → "General App" / OAuth) ---
# Add redirect URL:  http://localhost:8787/api/zoom/callback
# Add scope:         meeting:write  (create meetings)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Google Meet (console.cloud.google.com → enable "Google Calendar API") ---
# OAuth client type: Web application
# Authorized redirect URI:  http://localhost:8787/api/google/callback
# For "Continue with Google" sign-in, add a SECOND redirect URI to the SAME app:
#   http://localhost:8787/api/auth/oauth/google/callback   (scopes: openid email profile)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Yahoo sign-in (developer.yahoo.com → Create an App; OpenID Connect) ---
# Optional: enables the "Continue with Yahoo" button. Set the redirect/callback domain to:
#   http://localhost:8787/api/auth/oauth/yahoo/callback   (permissions: OpenID Connect — email, profile)
# (Proton is intentionally omitted — it offers no third-party "Sign in with Proton".)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# --- Stripe (dashboard.stripe.com → Developers → API keys; use TEST keys) ---
# Optional: without STRIPE_SECRET_KEY, paid plans unlock as a labelled simulation.
# Create two recurring Prices (Pro Desk, Trading Floor) and paste their price_… IDs.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_DESK=

# --- server / app origins (defaults are fine for local dev) ---
PORT=8787
PUBLIC_ORIGIN=http://localhost:8787
APP_ORIGIN=http://127.0.0.1:5173
